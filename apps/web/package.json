{
  "name": "@casa-dana/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "paraglide:watch": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --watch",
    "machine-translate": "inlang machine translate --project project.inlang",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@casa-dana/types": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@inlang/cli": "^3.0.0",
    "@inlang/paraglide-js": "^2.15.1",
    "@inlang/plugin-m-function-matcher": "^2.2.4",
    "@inlang/plugin-message-format": "^4.4.0",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10.4.27",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.8",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "vite": "^8"
  }
}
